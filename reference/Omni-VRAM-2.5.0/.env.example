# Omni-VRAM Configuration
# Copy this file to .env and fill in your values
# .env is git-ignored and will NOT be committed

# ── OpenAI API (for cloud Whisper) ──────────────────────────────
# Your OpenAI API key — used when backend=WHISPER_API
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
# Model name for OpenAI Whisper API
OPENAI_MODEL=whisper-1

# ── Whisper.cpp (for local transcription) ───────────────────────
# Path to the directory containing whisper.cpp executable (main.exe / main)
# Build from source: https://github.com/ggerganov/whisper.cpp
WHISPER_CPP_PATH=/path/to/whisper.cpp/build/bin
# Path to GGML model file (download from https://ggml.ggerganov.com/)
# Available models: ggml-tiny.bin, ggml-base.bin, ggml-small.bin, ggml-medium.bin
WHISPER_MODEL_PATH=/path/to/models/ggml-base.bin

# ── Whisper Model Settings ──────────────────────────────────────
# Model size for Python whisper library backend: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base
# Default backend: AUTO, WHISPER_CPP, WHISPER_API, WHISPER_PYTHON
# AUTO tries each backend in order: API → CLI → Python → None
WHISPER_BACKEND=AUTO
# Transcription output format: text, json, srt, vtt (used by whisper.cpp CLI)
WHISPER_OUTPUT_FORMAT=json
# Number of threads for whisper.cpp inference (0 = auto)
WHISPER_THREADS=0

# ── Audio Settings ──────────────────────────────────────────────
# Language code: zh (Chinese), en (English), ja (Japanese), etc.
# Leave empty for auto-detection
WHISPER_LANGUAGE=zh
# Target audio sample rate (Hz) — all audio is resampled to this rate
VRAM_SAMPLE_RATE=16000

# ── Stream Processor Settings ───────────────────────────────────
# VAD energy threshold (0.0-1.0) — lower = more sensitive
VAD_THRESHOLD=0.02
# Minimum speech duration in milliseconds to trigger transcription
MIN_SPEECH_DURATION_MS=300
# Silence duration in milliseconds to end a speech segment
SILENCE_DURATION_MS=500
# Maximum segment duration in seconds before forced transcription
MAX_SEGMENT_DURATION_S=30.0

# ── General Settings ────────────────────────────────────────────
# Compute device: cuda or cpu
VRAM_DEVICE=cuda
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
VRAM_LOG_LEVEL=INFO